{
  "version": 8,
  "name": "Truckly Base",
  "metadata": {
    "maputnik:renderer": "mbgljs"
  },
  "sources": {
    "osm-tiles": {
      "type": "raster",
      "tiles": [
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "osm-tiles",
      "type": "raster",
      "source": "osm-tiles",
      "minzoom": 0,
      "maxzoom": 19,
      "paint": {
        "raster-contrast": 0.18,
        "raster-saturation": 0.06,
        "raster-brightness-min": 0.02,
        "raster-brightness-max": 0.98
      }
    }
  ]
}
